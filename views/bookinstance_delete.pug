extends layout

block content

  h1= title

  p #[strong ......本当に、この本のインスタンスを消してもいいの？]

  div(style="margin-left:20px")

    p #[strong ID]: #{bookinstance._id}

    p #[strong タイトル: ]
      a(href=bookinstance.book.url) #{bookinstance.book.title}

    p #[strong 出版事項:] #{bookinstance.imprint}

    p #[strong ステータス: ]
      if bookinstance.status=='利用可能' || bookinstance.status=='Available'
        span.text-success #{bookinstance.status}
      else if bookinstance.status=='メンテナンス中' || bookinstance.status=='Maintenance'
        span.text-danger #{bookinstance.status}
      else
        span.text-warning #{bookinstance.status}

    if bookinstance.status!='利用可能' && bookinstance.status!='Available'
      p #[strong Due back:] #{bookinstance.due_back_formatted}

  form(method='POST')
    div.form-group
      input#id.form-control(type='hidden',name='id', value=bookinstance._id )

    button.btn.btn-primary(type='submit') 削除