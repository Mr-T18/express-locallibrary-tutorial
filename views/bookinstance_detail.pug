extends layout

block content

  h1 ID: #{bookinstance._id}

  p #[strong タイトル: ]
    a(href=bookinstance.book.url) #{bookinstance.book.title}
  p #[strong 出版事項:] #{bookinstance.imprint}

  p #[strong ステータス: ]
    if bookinstance.status=='利用可能'
      span.text-success #{bookinstance.status}
    else if bookinstance.status=='メンテナンス中'
      span.text-danger #{bookinstance.status}
    else
      span.text-warning #{bookinstance.status}

  if bookinstance.status!='利用可能'
    p #[strong 返却日:] #{bookinstance.due_back_formatted}

  hr
  p
    a(href=bookinstance.url+'/delete') 本のインスタンスを、「消す」
  p
    a(href=bookinstance.url+'/update') 本のインスタンスを、「更新する」